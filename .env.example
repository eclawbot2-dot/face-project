# Copy this file to .env.local (gitignored) and fill in real values.
# Next.js loads .env.local automatically in all environments.

# --- Database ---
# Use an ABSOLUTE path in production. A relative path will resolve against
# the working directory at runtime — if PM2 restarts in the wrong cwd you
# will silently start writing to a fresh empty SQLite file and lose history.
DATABASE_URL="file:/var/lib/face-project/data.db"

# --- Auth (NextAuth v5 / Auth.js) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""

# Public origin of the deployed app. NextAuth signs cookies/redirects against this.
NEXTAUTH_URL="https://face.jahdev.com"
AUTH_TRUST_HOST="true"

# --- Optional: error monitoring ---
# SENTRY_DSN=""
